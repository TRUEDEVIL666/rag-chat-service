sequenceDiagram
    title Upload Document Process
    actor User
    participant FE as Frontend (upload-document.html)
    participant BE as API Server

    User->>FE: Open Upload Page
    activate FE
    FE->>FE: Check Auth Token
    alt Token Missing
        FE->>User: Redirect to Login
    end
    
    User->>FE: Drag & Drop Files or Click Select
    FE->>FE: handleFiles()
    FE->>User: Update File List UI

    User->>FE: Change Chunking Method / Text
    FE->>FE: updateChunkPreview() (Client Simulation)
    FE->>User: Show Chunking Result

    User->>FE: Click "Start Upload"
    FE->>FE: Disable Button, Show Spinner
    
    FE->>BE: POST /api/v1/upload-file (FormData)
    activate BE
    
    alt Upload Success (200 OK)
        BE-->>FE: JSON Success Response
        FE->>User: Show Success Toast
        FE->>FE: Redirect to documents.html
    else Upload Failure
        BE-->>FE: Error Response
        deactivate BE
        FE->>User: Show Error Message
        FE->>FE: Re-enable Button
    end
    deactivate FE
