meta {
  name: Update Bot Config
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/bots/{{bot_id}}/config
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "config_prompt": "You are a helpful assistant.",
    "config_model": {
      "model": "gpt-3.5-turbo",
      "temperature": 0.7
    }
  }
}

vars:pre-request {
  bot_id: 
}
