meta {
  name: Create Bot
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/bots
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "My AI Assistant",
    "description": "A helpful assistant"
  }
}

script:post-response {
  if (res.body.id) {
    bru.setVar("bot_id", res.body.id);
  }
}
