meta {
  name: Create Knowledge Base
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/knowledge_bases
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "My Knowledge Base",
    "description": "Docs",
    "indexing_technique": "high_quality",
    "embedding_model": "text-embedding-3-small",
    "embedding_model_provider": "openai",
    "retrieval_model": {
      "search_method": "semantic",
      "reranking_enable": true,
      "reranking_mode": {
        "reranking_model": "huggingface/cross-encoder/ms-marco-MiniLM-L-6-v2"
      },
      "top_k": 5,
      "score_threshold_enabled": true,
      "score_threshold": 0.5,
      "weights": 0.5
    },
    "permission": "",
    "partial_member_list": []
  }
}

script:post-response {
  if (res.body.id) {
    bru.setVar("kb_id", res.body.id);
  }
}
