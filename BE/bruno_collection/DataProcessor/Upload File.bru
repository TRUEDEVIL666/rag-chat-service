meta {
  name: Upload File
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/upload-file
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

query {
}

body:multipart-form {
  files: @file()
  knowledge_base_id: 36bc7fc0-d495-47b2-b470-3b8345c1a1f1
}

script:post-response {
  if (res.status === 200) {
    const body = res.getBody();
    if (body.results && body.results.length > 0) {
      bru.setVar("task_id", body.results[0].task_id);
    }
  }
}
